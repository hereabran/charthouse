# Charthouse configuration — every value is optional. Copy to .env and edit.
# With no .env at all, Charthouse runs fully self-contained (in-memory shares).

# HTTP port for the self-hosted server (cmd/server). Default: 8080.
PORT=8080

# Share-link storage backend: memory | file | supabase. Default: memory.
#   memory   — ephemeral, in-process; zero config; links are lost on restart
#   file     — JSON files under SHARE_DIR; durable across restarts (good for Docker)
#   supabase — managed Postgres via the Supabase REST API (set the two vars below)
SHARE_STORE=memory

# Directory for the file store. Only used when SHARE_STORE=file. Default: ./data/shares.
SHARE_DIR=./data/shares

# Only needed when SHARE_STORE=supabase. Apply supabase/migrations/ first.
# The service-role key is SERVER-ONLY — never expose it to the browser bundle.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
